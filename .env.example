# Cobo Agentic Wallet — 从 `caw wallet current --show-api-key` 获取
# 见 docs/01-caw-onboarding.md
AGENT_WALLET_API_URL=https://api.agenticwallet.cobo.com
AGENT_WALLET_API_KEY=
AGENT_WALLET_WALLET_ID=

# 执行钱包(Strategy Agent 操作的钱包;MVP 单钱包即可)
EXECUTOR_WALLET_ID=

# LLM(Strategy Agent 决策用,任选其一填)
OPENAI_API_KEY=
ANTHROPIC_API_KEY=
# GLM-5.1(若想顺带蹭 Z.AI 或作 fallback,可选)
ZAI_API_KEY=

# 市场/价格数据源(触发条件判断用;无 key 可用公开行情或 mock feed)
# 见 docs/02 风险退路 1
PRICE_FEED_API_KEY=

# 可选:demo 收款/目标地址
CAW_DESTINATION=0x1111111111111111111111111111111111111111
